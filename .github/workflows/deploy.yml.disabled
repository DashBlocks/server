name: Deploy to server

on:
  push:
    branches:
      - main

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Deploy via SSH
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.SERVER_IP }}
          username: dash
          key: ${{ secrets.SSH_KEY }}
          script: |
            cd /opt/dash
            git pull origin main
            npm install --production
            sudo systemctl restart dash
